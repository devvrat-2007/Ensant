# FlowZint backend environment template.
# Copy to `.env` and fill in real values. NEVER commit the real `.env`.
#   cp .env.example .env

# ── Django ───────────────────────────────────────────────────────────────────
# Generate a key:  python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY="change-me-to-a-random-50-char-secret"
DEBUG="True"
ALLOWED_HOSTS="localhost,127.0.0.1"
CORS_ALLOWED_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"

# ── Database ─────────────────────────────────────────────────────────────────
# Leave DATABASE_URL unset to use the local SQLite file (dev default).
# For production, point it at Postgres (requires `psycopg` to be installed):
#   DATABASE_URL="postgres://user:password@host:5432/dbname"
# DATABASE_URL=""
# DB_CONN_MAX_AGE="600"   # persistent connection lifetime (seconds)

# ── Production security (only applied when DEBUG=False) ──────────────────────
# SECURE_SSL_REDIRECT="True"     # set False if TLS terminates upstream
# SECURE_HSTS_SECONDS="31536000" # start low (e.g. 3600) when first enabling
# LOG_LEVEL="INFO"               # DEBUG for verbose logging

# ── Vector Database (Pinecone) ───────────────────────────────────────────────
PINECONE_API_KEY="your-pinecone-api-key"
PINECONE_INDEX_NAME="flowzint-hackathon"

# ── Google AI Studio (Gemini / Gemma / embeddings) ───────────────────────────
# Either GEMINI_API_KEY or GOOGLE_API_KEY is accepted.
GEMINI_API_KEY="your-google-ai-studio-key"

# ── Model Orchestration providers (api/services/ai_service.py) ───────────────
# Required only for the routes that use them:
#   GROQ_API_KEY       → chat, guard
#   OPENROUTER_API_KEY → code, long_doc
#   DEEPSEEK_API_KEY   → (currently unused; kept for optional DeepSeek routing)
GROQ_API_KEY="your-groq-api-key"
OPENROUTER_API_KEY="your-openrouter-api-key"
DEEPSEEK_API_KEY=""

# ── Celery / Redis (broker on DB 0, results on DB 1) ─────────────────────────
CELERY_BROKER_URL="redis://localhost:6379/0"
CELERY_RESULT_BACKEND="redis://localhost:6379/1"

# ── Integrations ─────────────────────────────────────────────────────────────
# Optional. Leave blank to disable the Slack push feature.
SLACK_WEBHOOK_URL=""
